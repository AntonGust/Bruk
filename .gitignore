# OS / editor cruft
.DS_Store
Thumbs.db
*~
.*.swp
.vscode/
.idea/

# Local Claude Code config, skills, and tooling — machine-local, deliberately kept
# out of the (public) repo so box access details never get committed.
.claude/

# Local scratch / experiments (never the source of truth)
scratch/
tmp/
*.log

# Secrets must never be committed — they live in the cluster (k8s Secret) or a
# secret manager (SOPS, later), never in the repo.
*.key
*.pem
secrets.*
*.env
.env
